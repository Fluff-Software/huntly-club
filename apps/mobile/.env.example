# Supabase — local: use ngrok URL + anon key from `supabase status`; hosted: use project URL + anon key from Supabase dashboard → Settings → API
# Auth emails (sign-up verification, password reset) are sent via Mailjet from Edge Functions; see repo root supabase/EDGE_FUNCTION_SECRETS.md for Mailjet config (set as Supabase secrets, not here).
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# MapTiler (Android walk/cycle maps via MapLibre — iOS keeps Apple Maps)
# 1. Sign up: https://cloud.maptiler.com/
# 2. Create API key: https://cloud.maptiler.com/account/keys/new (do not use the default key for production)
# 3. After first dev build: restrict key (user-agent or signed requests) — see MapTiler usage logs for the User-Agent string
#    https://docs.maptiler.com/guides/maps-apis/maps-platform/how-to-protect-your-map-key/
# 4. Paste key below; add same name to EAS env for Android builds
# 5. After @maplibre/maplibre-react-native is added: run prebuild / EAS Android build (native rebuild required)
# Style: outdoor-v2 (default). Alternatives: streets-v2, topo-v2, satellite
EXPO_PUBLIC_MAPTILER_API_KEY=
# EXPO_PUBLIC_MAPTILER_STYLE_ID=outdoor-v2

# Google Maps (Android only for default MapView). google-services.json does NOT supply this.
# Cloud Console → enable "Maps SDK for Android" → Credentials → API key → restrict to Android app:
# package name = software.fluff.huntlyclub (see app.config.ts) + SHA-1 (local: run `gradlew signingReport` from `android/`, EAS: expo.dev project credentials).
# Set for local prebuild/run and add the same name to EAS env/secrets for dev builds.
# TODO: remove after MapLibre/MapTiler migration (step 6).
EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_API_KEY=

# EAS — required for EAS Build and EAS Update (get from https://expo.dev, project settings)
EXPO_PUBLIC_EAS_PROJECT_ID=
EXPO_PUBLIC_OWNER=
